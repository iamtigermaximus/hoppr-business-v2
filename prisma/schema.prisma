generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SHARED MODELS (from Hoppr Consumer App)
// ============================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String?
  googleId       String?   @unique
  phoneNumber    String?   @unique
  bio            String?   @db.Text
  avatarUrl      String?
  instagram      String?
  facebook       String?
  twitter        String?
  interests      String[]  @default([])
  languages      String[]  @default([])
  gallery        String[]  @default([])
  locationLat    Float?
  locationLng    Float?
  drinkPrefs     String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // -- Business app extensions --
  role           String    @default("CONSUMER")
  managedBars    String[]  @default([])
  isAgeVerified  Boolean   @default(false)

  accounts         Account[]
  sessions         Session[]
  eventsCreated    Event[]          @relation("EventCreator")
  eventJoins       EventParticipant[]
  chatMessages     ChatMessage[]
  passPurchases    PassPurchase[]
  notifications    Notification[]
  barManagers      BarManager[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id             String    @id @default(cuid())
  title          String
  description    String?   @db.Text
  venueId        String
  venueName      String
  venueType      String?
  startTime      DateTime
  endTime        DateTime?
  maxAttendees   Int?
  isPrivate      Boolean   @default(false)
  imageUrl       String?
  creatorId      String
  createdAt      DateTime  @default(now())

  creator       User               @relation("EventCreator", fields: [creatorId], references: [id])
  participants  EventParticipant[]
  chatRoom      ChatRoom?

  @@index([startTime])
  @@index([venueId])
}

model EventParticipant {
  userId    String
  eventId   String
  joinedAt  DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
  @@index([eventId])
}

model ChatRoom {
  id         String   @id @default(cuid())
  eventId    String   @unique
  createdAt  DateTime @default(now())

  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  content    String   @db.Text
  roomId     String
  authorId   String
  createdAt  DateTime @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id])

  @@index([roomId, createdAt])
}

model PassPurchase {
  id             String    @id @default(cuid())
  passId         String
  passTitle      String
  venueId        String
  venueName      String
  price          Float
  purchasedAt    DateTime  @default(now())
  validUntil     DateTime
  redeemedAt     DateTime?
  qrCodeSecret   String
  userId         String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String
  title      String
  body       String
  data       Json?
  isRead     Boolean  @default(false)
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// BUSINESS MODELS (Hoppr Business App)
// ============================================================

model Bar {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  address     String
  latitude    Float
  longitude   Float
  phone       String?
  email       String?
  website     String?
  imageUrl    String?
  gallery     String[]  @default([])
  hours       Json?
  amenities   String[]  @default([])
  socialLinks Json?
  isActive    Boolean   @default(true)
  claimStatus String    @default("UNCLAIMED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  promotions     Promotion[]
  passes         Pass[]
  managers       BarManager[]
  barAnalytics   BarAnalytics[]
  conversations  Conversation[]
  claimRequests  ClaimRequest[]
  socialPosts    SocialPost[]
  autoPilotRules AutoPilotRule[]
  aiInsights     AIInsight[]

  @@map("business_bars")
}

model ClaimRequest {
  id          String    @id @default(cuid())
  barId       String?
  barName     String
  barAddress  String?
  barCity     String?
  barType     String?
  claimantName String?
  claimantEmail String?
  claimantPhone String?
  notes       String?   @db.Text
  status      String    @default("PENDING")
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bar Bar? @relation(fields: [barId], references: [id])

  @@index([status])
  @@map("business_claim_requests")
}

model BarManager {
  id          String    @id @default(cuid())
  userId      String
  barId       String
  role        String    @default("MANAGER")
  permissions String[]  @default([])
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bar  Bar  @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@unique([userId, barId])
  @@map("business_bar_managers")
}

model Promotion {
  id                  String    @id @default(cuid())
  title               String
  description         String?   @db.Text
  barId               String
  imageUrl            String?
  startDate           DateTime
  endDate             DateTime
  discountType        String?
  discountValue       Float?
  termsAndConditions  String?   @db.Text
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@map("business_promotions")
}

model Pass {
  id            String    @id @default(cuid())
  title         String
  description   String?   @db.Text
  barId         String
  imageUrl      String?
  price         Float
  validFrom     DateTime
  validUntil    DateTime
  maxQuantity   Int?
  soldQuantity  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@map("business_passes")
}

model BarAnalytics {
  id                      String    @id @default(cuid())
  barId                   String
  date                    DateTime
  totalVisitors           Int       @default(0)
  totalRevenue            Float     @default(0)
  totalPassesSold         Int       @default(0)
  totalPromotionsRedeemed Int       @default(0)
  averageRating           Float?
  metrics                 Json?
  createdAt               DateTime  @default(now())

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@unique([barId, date])
  @@map("business_bar_analytics")
}

model Conversation {
  id            String    @id @default(cuid())
  participants  String[]  @default([])
  barId         String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bar      Bar?                   @relation(fields: [barId], references: [id])
  messages ConversationMessage[]

  @@map("business_conversations")
}

model ConversationMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("business_conversation_messages")
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@map("business_audit_logs")
}

model SocialPost {
  id           String    @id @default(cuid())
  barId        String
  bar          Bar       @relation(fields: [barId], references: [id], onDelete: Cascade)
  platform     String    @default("INSTAGRAM")
  content      String    @db.Text
  imageUrl     String?
  scheduledFor DateTime?
  publishedAt  DateTime?
  status       String    @default("DRAFT")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([barId, status])
  @@map("social_posts")
}

model AutoPilotRule {
  id          String   @id @default(cuid())
  barId       String
  bar         Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  name        String
  isEnabled   Boolean  @default(true)
  triggerType String   @default("TIME_BASED")
  triggerConfig Json?
  actionType  String   @default("CREATE_PROMOTION")
  actionConfig Json?
  lastTriggeredAt DateTime?
  cooldownHours   Int  @default(24)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([barId, isEnabled])
  @@map("auto_pilot_rules")
}

model AIInsight {
  id          String   @id @default(cuid())
  barId       String
  bar         Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  insightType String   @default("BEST_TIME")
  title       String
  description String
  confidence  Float    @default(0.8)
  isRead      Boolean  @default(false)
  isActioned  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([barId, isRead])
  @@map("ai_insights")
}
